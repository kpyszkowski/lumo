{
  "name": "@lumo/web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "predev": "docker compose up -d",
    "dev": "next dev --port 3000",
    "postdev": "docker compose down",
    "build": "next build",
    "postbuild": "opennextjs-cloudflare build -s",
    "start": "next start",
    "preview": "opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "eslint . --max-warnings 0",
    "format": "eslint . --fix",
    "check-types": "tsc --noEmit",
    "test": "NODE_ENV=test vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@lumo/ui": "workspace:^",
    "@neondatabase/serverless": "^1.0.0",
    "@opennextjs/cloudflare": "^1.16.0",
    "@orpc/client": "^1.10.4",
    "@orpc/contract": "^1.10.4",
    "@orpc/server": "^1.10.4",
    "@orpc/tanstack-query": "^1.11.1",
    "@tailwindcss/postcss": "^4.1.16",
    "@tanstack/react-query": "^5.90.7",
    "drizzle-orm": "^0.44.7",
    "jose": "^6.1.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.6",
    "postgres": "^3.4.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.1.11",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.14",
    "@lumo/configs": "workspace:^",
    "@lumo/scraper": "workspace:^",
    "@next/eslint-plugin-next": "^16.1.6",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.6",
    "@types/react-dom": "19.2.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-istanbul": "4.0.8",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.39.2",
    "prettier": "^3.6.2",
    "typescript": "5.9.2",
    "vite": "^5.4.21",
    "vitest": "4.0.8",
    "wrangler": "^4.46.0",
    "zod": "^4.1.12"
  }
}
