{
  "extends": "@lumo/configs/typescript/base.json",
  // "extends": "@lumo/configs/typescript/base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "jsx": "preserve",
    "noEmit": true,
    // Next.js seems to not support ${configDir} template variable.
    // Both `baseUrl` and `paths` needs to be rewritten with relative paths.
    "baseUrl": "./src",
    "paths": {
      "~/*": ["./*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "next-env.d.ts",
    "next.config.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
