    "@storybook/react-vite": "^9.1.2",
    "@tailwindcss/vite": "^4.1.11",
    "@types/react": "19.2.2",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/browser-playwright": "4.0.8",
