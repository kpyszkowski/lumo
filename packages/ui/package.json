{
  "name": "@lumo/ui",
  "version": "0.1.0",
  "private": true,
  "sideEffects": false,
  "exports": {
    "./theme": "./dist/theme.css",
    "./components": {
      "import": {
        "types": "./dist/components.d.ts",
        "default": "./dist/components.mjs"
      }
    },
    "./icons": {
      "import": {
        "types": "./dist/icons/index.d.ts",
        "default": "./dist/icons/index.mjs"
      }
    },
    "./utils": {
      "import": {
        "types": "./dist/utils.d.ts",
        "default": "./dist/utils.mjs"
      }
    },
    "./motion": {
      "import": {
        "types": "./dist/motion.d.ts",
        "default": "./dist/motion.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --clean=false",
    "clean": "rm -rf .turbo dist",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format": "eslint . --fix",
    "test": "vitest run"
  },
  "devDependencies": {
    "@lumo/configs": "workspace:^",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.6",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-istanbul": "4.0.8",
    "eslint": "^9.31.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tsdown": "^0.20.1",
    "tsx": "^4.20.5",
    "typescript": "5.9.2",
    "vitest": "4.0.8"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.11"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@tabler/icons-react": "^3.36.1",
    "motion": "^12.23.22",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^3.1.1"
  }
}
